-- --- SISTEMA DE ARRASTRE V5 ORIGINAL (ANTI-GLITCH) ---
local function setupDraggable(guiObject)
    local draggingInput = nil
    local dragStart, startPos

    guiObject.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and draggingInput == nil then
            draggingInput = input
            dragStart = input.Position
            startPos = guiObject.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == draggingInput then
            local delta = input.Position - dragStart
            guiObject.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input == draggingInput then
            draggingInput = nil
        end
    end)
end

