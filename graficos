-- 1. LIMPIEZA TOTAL
local function clear()
    for _, v in pairs(Lighting:GetChildren()) do
        if v.Name == "CustomEffect" or v.ClassName == "Sky" or v.ClassName == "Atmosphere" then 
            v:Destroy() 
        end
    end
    Lighting.ClockTime = 12
    Lighting.Brightness = 2
    Lighting.ExposureCompensation = 0
    Lighting.FogEnd = 100000
    Lighting.Ambient = Color3.fromRGB(127, 127, 127)
    Lighting.OutdoorAmbient = Color3.fromRGB(127, 127, 127)
end

-- --- FUNCIONES DE AMBIENTE ---

local function applyPinkSunset() -- EL NUEVO ATARDECER ROSADO CON CONTRASTES REALES
    clear()
    
    -- ColorCorrection equilibrado para contraste natural, no un filtro total
    local color = Instance.new("ColorCorrectionEffect", Lighting); color.Name = "CustomEffect"
    color.Saturation = 0.25; -- Saturación sutil
    color.Contrast = 0.15; -- Contraste ligero para definir formas
    color.TintColor = Color3.fromRGB(245, 230, 255) -- Tinte muy suave, casi blanco con toque fucsia
    
    -- Bloom para el resplandor de las luces
    local bloom = Instance.new("BloomEffect", Lighting); bloom.Name = "CustomEffect"
    bloom.Intensity = 0.4; bloom.Size = 16; bloom.Threshold = 0.75

    -- El secreto: Atmósfera Pesada con dispersión magenta/fucsia
    local atmosphere = Instance.new("Atmosphere", Lighting); atmosphere.Name = "CustomEffect"
    atmosphere.Density = 0.4; -- Neblina espesa para que la luz se disperse
    atmosphere.Offset = 0.05 -- Neblina cerca del suelo
    atmosphere.Color = Color3.fromRGB(220, 180, 200) -- Neblina color fucsia suave
    atmosphere.Decay = Color3.fromRGB(180, 50, 150) -- La luz al dispersarse se vuelve magenta/fucsia intenso
    atmosphere.Glare = 0.5 -- El sol se dispersa mucho
    atmosphere.Haze = 1.8 -- Bruma atmosférica densa

    -- Cielo fotorrealista (usamos el mismo que el dorado, la atmósfera hará el tinte)
    local sky = Instance.new("Sky", Lighting); sky.Name = "CustomEffect"
    sky.SkyboxBk = PINK_SKY_BASE_ID; sky.SkyboxDn = PINK_SKY_BASE_ID; sky.SkyboxFt = PINK_SKY_BASE_ID
    sky.SkyboxLf = PINK_SKY_BASE_ID; sky.SkyboxRt = PINK_SKY_BASE_ID; sky.SkyboxUp = PINK_SKY_BASE_ID
    
    -- Sol fotorrealista
    sky.SunTextureId = "rbxassetid://1084313264"; sky.SunAngularSize = 12
    
    -- Configuración de luz para realismo
    Lighting.ClockTime = 17.8 -- Hora del "Golden Hour" pero tirando a violeta
    Lighting.Brightness = 2.4 -- Brillo natural
    Lighting.ExposureCompensation = 0.0 -- Exposición estándar
    
    -- Ajuste sutil de luces ambientales para integrar el color magenta
    Lighting.Ambient = Color3.fromRGB(120, 100, 130) 
    Lighting.OutdoorAmbient = Color3.fromRGB(130, 110, 140)
end

